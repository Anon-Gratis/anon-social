<?xml version="1.0" encoding="utf-8"?>
<!-- Anon Social login screen — themed to match anonymous.gratis:
     pure black background, monospace, white/red accents, bracket-style buttons.
     IDs preserved so LoginActivity.kt bindings stay valid; the round-logo
     ImageView is kept but hidden so the binding ref remains live. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context="app.pachli.feature.login.LoginActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="72dp"
            android:paddingBottom="32dp">

            <!-- Round Pachli logo kept hidden so LoginActivity's
                 binding.loginLogo reference stays valid. -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/loginLogo"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone"
                android:contentDescription="@null"
                app:srcCompat="@mipmap/ic_launcher_round" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="// ANON SOCIAL"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.06"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="social.anonymous.gratis"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="36dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="─────────────────"
                android:textColor="#444444"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="28dp" />

            <TextView
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:text="federated. tor-routed. no SMTP, no recovery email, no phone. signing keys off-box."
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:textAlignment="center"
                android:layout_marginBottom="36dp" />

            <LinearLayout
                android:id="@+id/loginInputLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/domainTextInputLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_domain"
                    android:textColorHint="#888888"
                    app:boxStrokeColor="#FFFFFF"
                    app:hintTextColor="#FFFFFF"
                    app:boxStrokeErrorColor="#FF0000"
                    app:errorTextColor="#FF0000"
                    app:errorEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/domainEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ems="10"
                        android:fontFamily="monospace"
                        android:textColor="#FFFFFF"
                        android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loginButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="[ LOGIN ]"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    app:strokeColor="#FFFFFF"
                    app:strokeWidth="1dp"
                    app:cornerRadius="0dp"
                    app:rippleColor="#33FFFFFF"
                    app:backgroundTint="#000000" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/createAccountButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="[ // CREATE ACCOUNT ]"
                    android:textColor="#FF0000"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.08"
                    app:strokeColor="#FF0000"
                    app:strokeWidth="1dp"
                    app:cornerRadius="0dp"
                    app:rippleColor="#33FF0000"
                    app:backgroundTint="#000000"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/whatsAnInstanceTextView"
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:text="@string/link_whats_an_instance"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textAlignment="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/loginLoadingLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="#FFFFFF" />

                <TextView
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:text="@string/login_connection"
                    android:textColor="#CCCCCC"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:textAlignment="center" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="─────────────────"
                android:textColor="#444444"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="pgp: D1B6 F514 EB01 BA1E"
                android:textColor="#666666"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5486 740E E03B 35EB 06E1 136F"
                android:textColor="#666666"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.05"
                android:layout_marginTop="2dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@android:color/transparent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="#FFFFFF"
            android:background="@android:color/transparent" />
    </com.google.android.material.appbar.AppBarLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
